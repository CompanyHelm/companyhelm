# Copy this file to `apps/web/.env.local` for local Vite development.

# Use local auth by default for OSS self-hosting. Set this to `clerk` only when
# providing your own Clerk application configuration.
VITE_AUTH_PROVIDER=local

# Optional Clerk publishable key for deployments that opt into Clerk auth.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Clerk legal links for the hosted sign-up UI. When Clerk legal compliance is enabled,
# these URLs power the terms/privacy consent shown during sign-up.
VITE_CLERK_TERMS_OF_SERVICE_URL=https://example.com/terms
VITE_CLERK_PRIVACY_POLICY_URL=https://example.com/privacy

# Local API GraphQL endpoint.
# Keep local web and API on HTTP by default so Vite and the API share the same scheme.
# If you opt into HTTPS locally, change this to the matching HTTPS API URL too.
VITE_GRAPHQL_URL=http://localhost:4000/graphql

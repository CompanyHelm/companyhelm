{
  "name": "@companyhelm/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "if command -v watchman >/dev/null 2>&1; then npm run relay -- --watch & else npm run relay; fi; vite",
    "relay": "relay-compiler relay.config.json",
    "build": "npm run relay && vite build",
    "lint": "eslint src vite.config.ts --ext .ts,.tsx",
    "typecheck": "npm exec -- tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck",
    "test": "npm run check"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clerk/react": "^6.1.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/oxanium": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.1",
    "graphql-ws": "^6.0.8",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-relay": "^20.1.1",
    "relay-compiler": "^20.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}

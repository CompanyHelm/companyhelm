{
  "name": "@companyhelm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "audit:rls": "tsx scripts/check_rls_policies.ts",
    "dev": "tsx watch --include src/graphql/schema/schema.graphql server.ts --config-path ./config/local.yaml",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "lint": "eslint server.ts src scripts tests",
    "test": "npm run audit:rls && npm run check && vitest run",
    "typecheck": "npm exec -- tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck"
  },
  "devDependencies": {
    "@types/nunjucks": "^3.2.6",
    "drizzle-kit": "^0.31.9",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.2",
    "@daytonaio/sdk": "^0.157.0",
    "@e2b/desktop": "^2.2.2",
    "@fastify/cors": "^11.2.0",
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@redis/client": "^5.11.0",
    "bullmq": "^5.71.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "e2b": "^2.18.0",
    "exa-js": "^2.10.2",
    "fastify": "^5.2.1",
    "graphql-type-json": "^0.3.2",
    "inversify": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.1.0",
    "mercurius": "^16.8.0",
    "nunjucks": "^3.2.4",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "server.ts",
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}

# Copy this file to `apps/api/.env.local` for local development.
#
# The API loads `.env.local` automatically when started with
# `--config-path ./config/local.yaml`.

# Drizzle uses DATABASE_URL directly. The API runtime itself reads
# database role credentials from `apps/api/config/local.yaml`.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/companyhelm

# Required by `apps/api/config/local.yaml`.
EXA_API_KEY=exa_local_example
E2B_API_KEY=e2b_local_example
COMPANYHELM_OPENAI_API_KEY=sk-local-example

# GitHub App configuration.
GITHUB_APP_CLIENT_ID=Iv1.local-example
# Keep the PEM on a single line with literal `\n` escapes.
GITHUB_APP_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----
GITHUB_APP_URL=https://github.com/apps/companyhelm-local

# Clerk configuration.
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json

{
  "name": "companyhelm-ng",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "npm run dev -w @companyhelm/api",
    "dev:web": "npm run dev -w @companyhelm/web",
    "lint": "turbo run lint",
    "test": "turbo run lint build test",
    "db:generate": "npm exec -w @companyhelm/api -- drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "npm exec -w @companyhelm/api -- drizzle-kit migrate --config=drizzle.config.ts",
    "db:up": "docker compose up -d postgres redis pgadmin && echo \"pgAdmin: http://localhost:5050\" && echo \"Redis: localhost:6379\"",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis pgadmin && echo \"pgAdmin: http://localhost:5050\" && echo \"Redis: localhost:6379\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.57.1"
  }
}

    "figlet": "^1.9.4"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.44",
    "@types/figlet": "^1.7.0",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}

{
  "name": "companyhelm-ng",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build-e2b-templates": "npm run build-e2b-templates -w @companyhelm/server",
    "dev": "turbo run dev --filter=@companyhelm/server --filter=@companyhelm/web",
    "dev:api": "npm run dev -w @companyhelm/server",
    "dev:server": "npm run dev -w @companyhelm/server",
    "dev:runner": "npm run dev -w @companyhelm/runner",
    "dev:web": "npm run dev -w @companyhelm/web",
    "lint": "turbo run lint",
    "test": "npm run test:all",
    "db:generate": "npm exec -w @companyhelm/server -- drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "npm exec -w @companyhelm/server -- drizzle-kit migrate --config=drizzle.config.ts",
    "db:up": "docker compose up -d postgres redis pgadmin && echo \"pgAdmin: http://localhost:15050\" && echo \"Redis: localhost:16379\"",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis pgadmin && echo \"pgAdmin: http://localhost:15050\" && echo \"Redis: localhost:16379\"",
    "check": "npm run check:all",
    "check:api": "npm run check -w @companyhelm/server",
    "check:server": "npm run check -w @companyhelm/server",
    "check:runner": "npm run check -w @companyhelm/runner",
    "check:web": "npm run check -w @companyhelm/web",
    "check:all": "npm run check:api && npm run check:web && npm run check:runner",
    "postinstall": "patch-package",
    "test:api": "npm run test -w @companyhelm/server",
    "test:server": "npm run test -w @companyhelm/server",
    "test:runner": "npm run test -w @companyhelm/runner",
    "test:web": "npm run test -w @companyhelm/web",
    "test:all": "npm run test:api && npm run test:web && npm run test:runner",
    "local-dev": "tsx scripts/local/dev.ts",
    "local-e2b": "tsx scripts/local/e2b.ts",
    "demo:up": "tsx scripts/demo/up.ts",
    "demo:run": "tsx scripts/demo/run.ts",
    "seed:local-dev": "npm run seed:local-dev -w @companyhelm/server"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": "20.20.0",
    "npm": "11.6.2"
  },
  "version": "1.28.2",
  "dependencies": {
    "@e2b/desktop": "^2.2.2"
  }
}

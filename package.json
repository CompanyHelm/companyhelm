{
  "name": "@companyhelm/cli",
  "version": "0.1.0",
  "description": "Bootstrap and manage a local CompanyHelm deployment.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "companyhelm": "dist/cli.js"
  },
  "files": [

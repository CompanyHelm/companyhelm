{
  "name": "@companyhelm/cli",
  "version": "0.4.1",
  "description": "Bootstrap and manage a local CompanyHelm deployment.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CompanyHelm/companyhelm"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "companyhelm": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/templates",
    "src/config/image_config.ts"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && node scripts/copy-templates.cjs",
    "set-image-version": "npm run build && node dist/cli.js set-image-version",
    "start": "npm run build && node dist/cli.js",
    "test": "npm run build && vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@companyhelm/runner": "^0.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "dockerode": "^4.0.9",
    "figlet": "^1.9.4",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.44",
    "@types/figlet": "^1.7.0",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}

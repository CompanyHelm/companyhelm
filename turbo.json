{
    "$schema": "https://turborepo.dev/schema.json",
    "tasks": {
      "build": {
        "outputs": ["dist/**"]
      },
      "lint": {},
      "check-types": {
        "dependsOn": ["^check-types"]
      },
      "test": {
        "dependsOn": ["lint"]
      },
      "dev": {
        "persistent": true,
        "cache": false
      }
    }
  }

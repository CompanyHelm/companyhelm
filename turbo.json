{
    "$schema": "https://turborepo.dev/schema.json",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": ["dist/**"]
      },
      "lint": {},
      "typecheck": {
        "dependsOn": ["^typecheck"]
      },
      "check": {
        "dependsOn": ["^build"]
      },
      "test": {
        "dependsOn": ["lint", "^build"]
      },
      "dev": {
        "persistent": true,
        "cache": false
      }
    }
  }

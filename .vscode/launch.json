{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/api",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": [
        "watch",
        "--include",
        "src/graphql/schema/schema.graphql",
        "src/main.ts",
        "--config-path",
        "${workspaceFolder}/apps/api/config/local.yaml"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "outputCapture": "std",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "API (dev)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/api",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": [
        "watch",
        "--include",
        "src/graphql/schema/schema.graphql",
        "src/main.ts",
        "--config-path",
        "${workspaceFolder}/apps/api/config/dev.yaml"
      ],
      "envFile": "${workspaceFolder}/apps/api/.env.dev",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "outputCapture": "std",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/web",
      "command": "npm run dev"
    },
    {
      "name": "Web (Brave)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/web",
      "runtimeExecutable": "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser",
      "presentation": {
        "group": "web",
        "order": 2
      }
    }
  ],
  "compounds": [
    {
      "name": "Web + API",
      "configurations": ["Web Dev Server", "API"],
      "stopAll": true
    },
    {
      "name": "Full Stack (API + Web + Brave)",
      "configurations": ["API", "Web Dev Server", "Web (Brave)"],
      "stopAll": true
    },
    {
      "name": "Full Stack (API dev + Web + Brave)",
      "configurations": ["API (dev)", "Web Dev Server", "Web (Brave)"],
      "stopAll": true
    }
  ]
}

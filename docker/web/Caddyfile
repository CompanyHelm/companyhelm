:4173 {
  root * /srv

  handle_errors 404 {
    @missingHashedAsset path /assets/*
    handle @missingHashedAsset {
      header Cache-Control "no-store, no-cache, must-revalidate"
      respond "{err.status_code} {err.status_text}" {err.status_code}
    }
  }

  @runtimeConfig path /runtime-config.js
  handle @runtimeConfig {
    header Cache-Control "no-store, no-cache, must-revalidate"
    file_server
  }

  @hashedAssets path /assets/*
  handle @hashedAssets {
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  @staticFiles path_regexp staticFiles \.(?:css|js|mjs|map|svg|png|jpe?g|gif|webp|ico|woff2?|ttf|eot|txt|xml|webmanifest)$
  handle @staticFiles {
    header Cache-Control "no-cache, must-revalidate"
    file_server
  }

  handle {
    header Cache-Control "no-cache, must-revalidate"
    try_files {path} /index.html
    file_server
  }
}
